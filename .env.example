APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------
# PRIMARY DATABASE (MySQL via XAMPP — non-standard port 3307)
# This is the main CRM database. Run all migrations against this.
# -----------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=your_crm_database_name
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------
# LEGACY DATABASE (read-only, used only by the MigrateLegacyContacts command)
# Port 3306 — separate MySQL instance. Never run migrations against this.
# Leave blank if you don't have access to the legacy system.
# -----------------------------------------------------------------------
DB_LEGACY_CONNECTION=mysql
DB_LEGACY_HOST=127.0.0.1
DB_LEGACY_PORT=3306
DB_LEGACY_DATABASE=your_legacy_database_name
DB_LEGACY_USERNAME=root
DB_LEGACY_PASSWORD=

# -----------------------------------------------------------------------
# EXHIBITIONS DATABASE (read-only, used only by import/reporting commands)
# Port 3306 — separate MySQL instance. Never run migrations against this.
# Leave blank if you don't have access to the exhibitions system.
# -----------------------------------------------------------------------
DB_EXHIBITIONS_HOST=127.0.0.1
DB_EXHIBITIONS_PORT=3306
DB_EXHIBITIONS_DATABASE=your_exhibitions_database_name
DB_EXHIBITIONS_USERNAME=root
DB_EXHIBITIONS_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache driver — use 'database' for local dev, switch to 'redis' in production
# See DEFERRED_WORK.md > Priority 3 for Redis setup instructions
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
# Base path for Vite-built assets. Match your XAMPP subpath for local dev.
# In production, set to '/' (root domain) or '/subfolder/' as appropriate.
VITE_BASE_URL=/library_crm_v2/public/

# -----------------------------------------------------------------------
# EMAIL CAMPAIGNS — sender addresses shown in the SMTP Settings provider picker
# Comma-separated list of "From" addresses per provider.
# -----------------------------------------------------------------------
EMAIL_CAMPAIGN_GMAIL_SENDERS=
EMAIL_CAMPAIGN_OUTLOOK_SENDERS=

# -----------------------------------------------------------------------
# PROPOSAL GENERATOR — company contact details shown on generated proposals
# -----------------------------------------------------------------------
PROPOSAL_COMPANY_EMAIL=

# -----------------------------------------------------------------------
# DEV SUPER ADMIN SEEDER — local-only, never run via DevelopmentSuperAdminSeeder in production
# -----------------------------------------------------------------------
DEV_SUPER_ADMIN_EMAIL=superadmin@example.com
DEV_SUPER_ADMIN_PASSWORD=
